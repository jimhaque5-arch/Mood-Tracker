# ── Required ────────────────────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Get a free key at https://portal.cdp.coinbase.com
NEXT_PUBLIC_CDP_API_KEY=your_coinbase_developer_platform_key_here

# Your deployed contract on Base Mainnet (already set for you)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x786943cC2bbC0149A71B63fA1782298E1AA82091

# ── Optional ────────────────────────────────────────────────────────
# Use "mainnet" for production, "testnet" for Base Sepolia
NEXT_PUBLIC_NETWORK=mainnet

# App URL (update after deploying to Vercel)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
